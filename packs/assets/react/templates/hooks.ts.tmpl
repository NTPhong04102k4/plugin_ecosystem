// Trích type response từ `operations` do openapi-typescript sinh (2xx JSON body).
type OpRes<Op extends keyof operations> = operations[Op] extends { responses: infer R }
  ? R extends { 200: { content: { 'application/json': infer T } } }
    ? T
    : R extends { 201: { content: { 'application/json': infer T } } }
      ? T
      : unknown
  : unknown
{{- end}}

async function request<T>(
  method: string,
  path: string,
  init?: { query?: Record<string, unknown>; body?: unknown },
): Promise<T> {
  let url = BASE + path
  if (init?.query) {
    const qs = new URLSearchParams()
    for (const [k, v] of Object.entries(init.query)) if (v != null) qs.set(k, String(v))
    const s = qs.toString()
    if (s) url += '?' + s
  }
  const res = await fetch(url, {
    method,
    headers: init?.body != null ? { 'Content-Type': 'application/json' } : undefined,
    body: init?.body != null ? JSON.stringify(init.body) : undefined,
  })
  if (!res.ok) throw new Error(`${method} ${path} -> ${res.status}`)
  return res.status === 204 ? (undefined as T) : ((await res.json()) as T)
}
